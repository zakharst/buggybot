{
  "name": "buggybot",
  "version": "0.1.0",
  "private": true,
  "description": "Slack→Azure DevOps bugs. Postgres via Vercel Marketplace Neon; DATABASE_URL is the only DB env var.",
  "scripts": {
    "dev": "next dev",
    "db:push": "drizzle-kit push",
    "db:push:ci": "drizzle-kit push --force",
    "prebuild": "node scripts/vercel-db-push.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:slack-ado": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs --tsconfig tsconfig.json scripts/smoke-slack-ado-bug.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "ado:list-bug-fields": "node scripts/ado-list-required-bug-fields.mjs",
    "ado:snapshot-required-field-refs": "node --env-file=.env scripts/ado-snapshot-required-field-refs.mjs",
    "ado:inspect-bug-layout": "node --env-file=.env scripts/ado-inspect-bug-layout.mjs",
    "openai:snapshot-bug-examples": "node --env-file=.env scripts/openai-snapshot-bug-examples.mjs",
    "ado:snapshot-bug-backlog-md": "node --env-file=.env scripts/ado-snapshot-bug-backlog-md.mjs",
    "openai:derive-style-from-backlog": "node scripts/openai-derive-style-from-backlog.mjs"
  },
  "dependencies": {
    "@slack/web-api": "^7.8.0",
    "@vercel/functions": "^3.4.3",
    "drizzle-kit": "^0.30.1",
    "drizzle-orm": "^0.36.4",
    "next": "^15.1.0",
    "openai": "^4.77.0",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
