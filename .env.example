# =============================================================================
# Postgres — Vercel Marketplace (Neon) or Neon console
# =============================================================================
# This app reads DATABASE_URL only (no POSTGRES_URL, PRISMA_DATABASE_URL, etc.).
#
# Production (Vercel): Project → Storage → Create database → Neon.
#   Vercel injects DATABASE_URL (pooled postgresql://…).
#
# Local: Neon dashboard → Connection details → pooled URI → paste below.
# =============================================================================
DATABASE_URL=

# --- Slack (HTTP Interactivity; optional Events API for :ladybug: reaction → same bug flow) ---
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
# Event Subscriptions URL: ${APP_BASE_URL}/api/slack/events — subscribe to reaction_added; scope reactions:read
# If :ladybug: does nothing: bot must be IN the channel; reinstall app after adding Events; see README.
# Custom emoji trigger: set the Events API `reaction` string (Slack API Explorer or:)
# SLACK_DEBUG_REACTIONS=1  # logs every Events API event_callback (eventType, etc.) → /admin Logs.
# SLACK_LADYBUG_DIAG=1     # logs each reaction_added with parseMatched / teamId / reaction vs allowed (debug only).
#   Does nothing for reactions if Event Subscriptions URL is not set to …/api/slack/events (see README).
# Trigger emoji: API name is ladybug (no colons). You may paste :ladybug: — we strip colons.
# SLACK_LADYBUG_REACTION_NAMES=ladybug
# SLACK_LADYBUG_REACTION_NAMES=:ladybug:,my_custom_bug_emoji
# Optional: ignore reactions added by the bot (auth.test → user id) to avoid accidental self-triggers
# SLACK_BOT_USER_ID=U01234567
# SLACK_DEBUG_INTERACTIONS=1  # verbose safe logs: pathname, payload type, pipeline checkpoints (no secrets)
# Bot scopes for media → ADO: files:read, channels:history, groups:history (see README §4)
# Admin "Assign to reporter": users:read + users:read.email (Slack profile email → ADO AssignedTo)

# --- OpenAI ---
OPENAI_API_KEY=sk-your-key
# Default in code is gpt-4o (stronger than mini). Override if needed:
# OPENAI_MODEL=gpt-4o
# Frontier (if your org has access): try gpt-5.4 — verify Chat Completions + structured outputs in your account.
# Second pass polishes JSON — ON by default (~2× OpenAI cost per bug). Disable to save one call:
# OPENAI_BUG_REFINE_SECOND_PASS=0
# Few-shot from ADO: npm run openai:snapshot-bug-examples  (optional OPENAI_BUG_EXAMPLES_COUNT=20)
# Edit config/openai-bug-examples.json → systemPromptExtra for your QA voice / rules
# Long backlog (markdown) appended to system prompt: config/openai-bug-backlog-examples.md
# OPENAI_BACKLOG_EXAMPLES_MD=path/to/other.md
# After refreshing backlog: npm run openai:derive-style-from-backlog → config/openai-bug-style-guide.md (primary context; raw backlog off by default when this file exists)
# OPENAI_BUG_STYLE_GUIDE_MD=path/to/other-style.md
# Optional: append raw backlog on intake (chars, 0=off). Default 0 if style guide present, else ~48k of backlog file.
# OPENAI_BUG_RAW_BACKLOG_MAX_CHARS=120000
# Refine pass: raw backlog off by default (saves tokens). Uncomment to mirror intake:
# OPENAI_BUG_REFINE_RAW_BACKLOG_MAX_CHARS=120000

# Slack bug Description: Build line from env; Environment (dev/prod) + Platform (iOS/Android) from OpenAI.
# SLACK_BUG_APP_BUILD=3.5.0_OTA_2
# Refresh backlog markdown for OpenAI (default 500 bugs): npm run ado:snapshot-bug-backlog-md
# ADO_BACKLOG_MD_COUNT=500
# ADO_BACKLOG_MD_OUT=config/openai-bug-backlog-examples.md

# --- Azure DevOps (REST; PAT needs Work Items read/write) ---
AZURE_DEVOPS_PAT=your-pat
AZURE_DEVOPS_ORG=your-org
AZURE_DEVOPS_PROJECT=your-project
# AZURE_DEVOPS_WORK_ITEM_TYPE=Bug
# Map Buggybot → your Bug type (refs, tabs, required): npm run ado:inspect-bug-layout
# OpenAI prompt: committed config/ado-bug-required-field-refs.json (refresh locally, no ADO per Slack message):
#   npm run ado:snapshot-required-field-refs   # needs AZURE_DEVOPS_* + PAT in .env
# Slack bugs always set Custom.Reportedfrom (default picklist label DT team — override if yours differs):
# AZURE_DEVOPS_REPORTED_FROM=DT team
# AZURE_DEVOPS_REPORTED_FROM_FIELD_REF=YourOrg.ReportedFrom
# One JSON object in env for field values on create (no ADO query per bug):
# npm run ado:list-bug-fields — hints for AZURE_DEVOPS_REQUIRED_FIELD_VALUES
# AZURE_DEVOPS_REQUIRED_FIELD_VALUES={"System.AreaPath":"Project\\Team","System.Tags":"production","Microsoft.VSTS.Common.ValueArea":"Business"}
# Do not use @CurrentIteration in JSON — Boards macro; REST create needs a real path or use iteration team below.
# AZURE_DEVOPS_REQUIRED_FIELD_VALUES={"System.IterationPath":"Project\\Release 1\\Sprint 3"}
# Copy Area from an existing work item (e.g. template bug) and/or set Iteration to the team’s *current* sprint via API (overrides Area/Iteration from REQUIRED_FIELD_VALUES when successful).
# Prefer setting these in /admin (Postgres); env is fallback when admin fields are empty:
# AZURE_DEVOPS_TEMPLATE_WORK_ITEM_ID=20741
# AZURE_DEVOPS_ITERATION_TEAM_NAME=Digital-Services Team
# If TF401347 on System.IterationPath: remove IterationPath from REQUIRED_FIELD_VALUES or set:
# AZURE_DEVOPS_OMIT_ITERATION_PATH=1
# Bug layout tabs (Repro Steps / System Info / Acceptance Criteria) — filled from OpenAI; disable if create returns 400:
# AZURE_DEVOPS_DISABLE_TCM_TAB_FILL=1
# AZURE_DEVOPS_DISABLE_ACCEPTANCE_CRITERIA_TAB=1   # if your Bug type has no Acceptance Criteria field
# Optional ref overrides (defaults: Microsoft.VSTS.TCM.ReproSteps, .SystemInfo, Microsoft.VSTS.Common.AcceptanceCriteria):
# AZURE_DEVOPS_REPRO_STEPS_FIELD_REF=
# AZURE_DEVOPS_SYSTEM_INFO_FIELD_REF=
# AZURE_DEVOPS_ACCEPTANCE_CRITERIA_FIELD_REF=
# Lower-level alternative: raw JSON Patch array (applied after REQUIRED_FIELD_VALUES):
# AZURE_DEVOPS_CREATE_EXTRA_PATCH=[{"op":"add","path":"/fields/YourOrg.ReportedFrom","value":"Slack"}]
# Slack screenshots/videos → ADO: toggle + limits in /admin (Slack → ADO attachments).
# ADO Services: 60 MB/file (app default). DevOps Server only — raise if your collection allows it:
# AZURE_DEVOPS_MAX_ATTACHMENT_BYTES=134217728
# Sum of all media bytes in RAM before upload (default ~220 MiB); lower if functions OOM:
# SLACK_MEDIA_MAX_TOTAL_BYTES=104857600
# AZURE_DEVOPS_DISABLE_SLACK_ATTACHMENTS=1   # optional: force off regardless of /admin

# --- /admin — HTTP Basic Auth ---
ADMIN_BASIC_AUTH_USER=admin
ADMIN_BASIC_AUTH_PASSWORD=change-me-to-a-long-random-secret
# Optional: Bearer for GET /api/admin/logs (export JSON/NDJSON via curl). If unset, only Basic works.
# ADMIN_LOGS_BEARER=another-long-random

# --- Public origin (admin shows Slack Interactivity URL) ---
# Production: https://your-deployment.vercel.app (no trailing slash)
APP_BASE_URL=
