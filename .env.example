# =============================================================================
# Postgres — Vercel Marketplace (Neon) or Neon console
# =============================================================================
# This app reads DATABASE_URL only (no POSTGRES_URL, PRISMA_DATABASE_URL, etc.).
#
# Production (Vercel): Project → Storage → Create database → Neon.
#   Vercel injects DATABASE_URL (pooled postgresql://…).
#
# Local: Neon dashboard → Connection details → pooled URI → paste below.
# =============================================================================
DATABASE_URL=

# --- Slack (HTTP Interactivity only; no Socket Mode) ---
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# --- OpenAI ---
OPENAI_API_KEY=sk-your-key
# OPENAI_MODEL=gpt-4o-mini

# --- Azure DevOps (REST; PAT needs Work Items read/write) ---
AZURE_DEVOPS_PAT=your-pat
AZURE_DEVOPS_ORG=your-org
AZURE_DEVOPS_PROJECT=your-project
# AZURE_DEVOPS_WORK_ITEM_TYPE=Bug

# --- /admin — HTTP Basic Auth ---
ADMIN_BASIC_AUTH_USER=admin
ADMIN_BASIC_AUTH_PASSWORD=change-me-to-a-long-random-secret

# --- Public origin (admin shows Slack Interactivity URL) ---
# Production: https://your-deployment.vercel.app (no trailing slash)
APP_BASE_URL=
